# Aroha Flow – environment variables
# Copy this file to .env and fill in your values. Do not commit .env.

# Data source: "local" (browser localStorage, no backend) or "production" (Supabase)
VITE_DATA_SOURCE=local

# Required when VITE_DATA_SOURCE=production (from Supabase project: Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: for "Add Recipe with AI" (URL parsing) in Meal Planning
OPENAI_API_KEY=
